{
  "name": "skyraksys-hrm-frontend",
  "version": "2.0.0",
  "private": true,
  "proxy": "http://localhost:5000",
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@mui/x-data-grid": "^6.18.0",
    "@mui/x-date-pickers": "^5.0.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "axios": "^1.11.0",
    "date-fns": "^2.30.0",
    "dayjs": "^1.11.13",
    "ffmpeg-static": "^5.3.0",
    "file-saver": "^2.0.5",
    "notistack": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.48.0",
    "react-router-dom": "^6.25.1",
    "react-scripts": "5.0.1",
    "recharts": "^2.8.0",
    "xlsx": "^0.18.5",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "cross-env": "^10.1.0",
    "msw": "^2.12.7",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:analyze": "react-scripts build && npx serve -s build",
    "analyze": "npm run build && npx webpack-bundle-analyzer build/static/js/*.js",
    "test": "react-scripts test",
    "test:ui": "react-scripts test --watchAll=false --no-coverage --forceExit --maxWorkers=2",
    "test:integration": "cross-env REACT_APP_TEST_MODE=integration react-scripts test --watchAll=false --no-coverage --forceExit --maxWorkers=2",
    "test:integration:verbose": "cross-env REACT_APP_TEST_MODE=integration react-scripts test --watchAll=false --no-coverage --forceExit --verbose --maxWorkers=2",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "e2e": "node run-test.js",
    "e2e:watch": "node run-test.js --watch",
    "e2e:status": "node run-test.js --status",
    "e2e:last": "node run-test.js --last",
    "e2e:excel": "npx playwright test --config=playwright-excel.config.js",
    "eject": "react-scripts eject",
    "performance:test": "npm run build && npx lighthouse http://localhost:3000 --output=html --output-path=./performance-report.html",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "test:watch": "react-scripts test --watch",
    "clean:build": "rimraf build",
    "serve:prod": "npx serve -s build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "security-check": "npm audit && npm outdated",
    "type-check": "tsc --noEmit",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:login": "npx playwright test login.spec.js",
    "test:e2e:employee": "npx playwright test employee.spec.js",
    "test:e2e:leave": "npx playwright test leave.spec.js",
    "test:e2e:timesheet": "npx playwright test timesheet.spec.js",
    "test:e2e:payroll": "npx playwright test payroll.spec.js",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:chromium": "npx playwright test --project=chromium",
    "test:e2e:firefox": "npx playwright test --project=firefox",
    "test:e2e:webkit": "npx playwright test --project=webkit",
    "generate:testdata": "node e2e/utils/generateTestData.js",
    "test:e2e:integration": "npx playwright test specs/integration/",
    "test:e2e:ui-only": "npx playwright test --ignore=e2e/specs/integration",
    "test:e2e:excel": "npx playwright test -c playwright-excel.config.js",
    "test:e2e:excel:headed": "npx playwright test -c playwright-excel.config.js --headed",
    "test:e2e:excel:ui": "npx playwright test -c playwright-excel.config.js --ui",
    "test:e2e:excel:debug": "npx playwright test -c playwright-excel.config.js --debug",
    "test:e2e:excel:report": "npx playwright show-report playwright-report"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error"
          ]
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "/node_modules/(?!axios)/"
    ],
    "moduleNameMapper": {
      "^react-chartjs-2$": "<rootDir>/src/__mocks__/react-chartjs-2.js"
    }
  }
}
