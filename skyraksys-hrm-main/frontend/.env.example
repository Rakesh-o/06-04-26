# ========================================
# SKYRAKSYS HRM - Frontend Environment
# ========================================
# Copy this file to .env and fill in values.
# CRA automatically loads .env files (see: https://create-react-app.dev/docs/adding-custom-environment-variables/)

# Backend API base URL (with /api suffix)
REACT_APP_API_URL=http://localhost:5000/api

# Backend server URL (without /api, used for photo URLs etc.)
REACT_APP_BACKEND_URL=http://localhost:5000
