# Integration Test Configuration
# Copy this to .env.test.local and fill in real values when running integration tests.
# The backend must be running at the configured URL.

REACT_APP_TEST_MODE=integration
REACT_APP_API_URL=http://localhost:5000/api

# Test user credentials (must exist in the database)
TEST_ADMIN_EMAIL=admin@skyraksys.com
TEST_ADMIN_PASSWORD=

TEST_HR_EMAIL=hr@skyraksys.com
TEST_HR_PASSWORD=

TEST_MANAGER_EMAIL=lead@skyraksys.com
TEST_MANAGER_PASSWORD=

TEST_EMPLOYEE_EMAIL=employee1@skyraksys.com
TEST_EMPLOYEE_PASSWORD=

# Timeouts (ms)
TEST_API_TIMEOUT=10000
TEST_TIMEOUT=30000
