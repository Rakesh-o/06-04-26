# ==============================================================================
# SkyRakSys HRM - Backend Environment Configuration
# ==============================================================================
# Copy this file to .env and update with your settings
# For Red Hat deployment, see: DEPLOYMENT_GUIDE.md
# ==============================================================================

# --- Application ---
NODE_ENV=development
# Options: development | test | production
PORT=5000
HOST=0.0.0.0

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skyraksys_hrm
DB_NAME_TEST=skyraksys_hrm_test
DB_USER=hrm_app
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_DIALECT=postgres
DB_SSL=false
# DB_POOL_MAX=10
# DB_POOL_MIN=2

# --- JWT Authentication ---
JWT_SECRET=CHANGE_ME_use_64char_random_string
JWT_REFRESH_SECRET=CHANGE_ME_use_different_64char_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Security ---
BCRYPT_ROUNDS=12
# ENCRYPTION_KEY=CHANGE_ME_generate_with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=20
# TRUST_PROXY=true                  # Enable when behind Nginx

# --- CORS ---
# Comma-separated list of allowed origins (no spaces)
# For production, include all frontend access points with their ports
# Example: CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://46.225.73.94,http://46.225.73.94:3000,http://46.225.73.94:8080
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# CORS_ALLOW_ALL=false              # NEVER true in production

# --- Demo Data Seeding ---
SEED_DEMO_DATA=false
SEED_DEFAULT_PASSWORD=admin123

# --- Email (SMTP) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# EMAIL_FROM=noreply@skyraksys.com

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5000000

# --- Logging ---
# ENABLE_QUERY_LOGGING=false
# LOG_ALL_QUERIES=false

# --- Production Only ---
# API_BASE_URL=https://your-domain.com
# DOMAIN=your-domain.com
# ENABLE_STATUS_MONITOR=false
  
# Cookie security: set to true when serving over HTTPS  
COOKIE_SECURE=false 
